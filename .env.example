# 100% Free Google Sheet Database Configuration for Render / Cloud Hosting

# 1. Google Sheet Document ID (Default: TipBitte Master Task & Roster Sheet)
GOOGLE_SHEET_ID=1zjcbkAkIv2-g1629Eax2S1SO_5uGTxKghJSsvSjcfx0

# 2. Optional: Google Service Account Email & Private Key (for direct Google Sheet row writes)
# Create a free Service Account in Google Cloud Console, then share your Google Sheet with this email address.
GOOGLE_SERVICE_ACCOUNT_EMAIL=tipbitte-resto-app@your-project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_LINES_HERE\n-----END PRIVATE KEY-----\n"

# 3. Optional: Google Apps Script WebApp Webhook Endpoint (Alternative zero-key write method)
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/AKfycbx_your_script_id/exec
